# ============================================================
# Studio Z Academy — Environment Variables
# Copy this file to .env.local and fill in the values
# See: docs/operacion/MANEJO_SECRETOS.md
# ============================================================

# Supabase (new key format: publishable replaces anon, secret replaces service_role)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxx

# Wompi
NEXT_PUBLIC_WOMPI_PUBLIC_KEY=pub_test_xxxxx
WOMPI_PRIVATE_KEY=prv_test_xxxxx
WOMPI_EVENTS_SECRET=test_events_xxxxx
WOMPI_INTEGRITY_KEY=test_integrity_xxxxx
WOMPI_API_BASE_URL=https://sandbox.wompi.co/v1
WOMPI_CHECKOUT_URL=https://checkout.wompi.co/p/

# Bunny Stream
BUNNY_API_KEY=xxxxx-xxxxx-xxxxx
BUNNY_LIBRARY_ID=12345
BUNNY_CDN_HOSTNAME=vz-xxxxx.b-cdn.net
BUNNY_TOKEN_AUTH_KEY=xxxxx

# Email (Resend)
RESEND_API_KEY=re_xxxxx

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
WHATSAPP_NUMBER=573001234567

# Optional: protected staging on Vercel
# Use the same value configured in Vercel "Protection Bypass for Automation"
VERCEL_AUTOMATION_BYPASS_SECRET=

# Optional: QA Bunny media IDs for shared Playwright/staging seeds
QA_BUNNY_PREVIEW_VIDEO_ID=
QA_BUNNY_LESSON_VIDEO_ID_PREVIEW=
QA_BUNNY_LESSON_VIDEO_ID_MAIN=
