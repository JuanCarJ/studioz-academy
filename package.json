{
  "name": "studioz-academy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:bunny": "PLAYWRIGHT_BUNNY_ENABLED=1 playwright test e2e/bunny-integration.spec.ts --project=desktop-chromium",
    "test:wompi": "PLAYWRIGHT_USE_EXISTING_SERVER=0 playwright test e2e/wompi-checkout-web.spec.ts e2e/wompi-sandbox.spec.ts e2e/wompi-capabilities.spec.ts --project=desktop-chromium",
    "test:wompi:checkout": "PLAYWRIGHT_USE_EXISTING_SERVER=0 playwright test e2e/wompi-checkout-web.spec.ts --project=desktop-chromium",
    "test:wompi:sandbox": "PLAYWRIGHT_USE_EXISTING_SERVER=1 playwright test e2e/wompi-sandbox.spec.ts --project=desktop-chromium",
    "test:wompi:capabilities": "PLAYWRIGHT_USE_EXISTING_SERVER=1 playwright test e2e/wompi-capabilities.spec.ts --project=desktop-chromium",
    "auth:cleanup-deleted-users": "node scripts/auth/cleanup-deleted-users.mjs",
    "qa:seed": "node scripts/qa/seed-staging.mjs",
    "qa:reset": "node scripts/qa/reset-staging.mjs",
    "wompi:webhook:url": "node scripts/wompi/print-webhook-url.mjs"
  },
  "dependencies": {
    "@react-email/components": "^1.0.8",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "resend": "^6.9.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tus-js-client": "^4.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
